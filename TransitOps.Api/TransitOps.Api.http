@TransitOps.Api_HostAddress = http://localhost:8080
@transportId = 40000000-0000-0000-0000-000000000001
@vehicleId = 30000000-0000-0000-0000-000000000001
@driverId = 20000000-0000-0000-0000-000000000001
@seededAdminUsername = seed.admin
@seededAdminPassword = SeedAdmin!123
@bootstrapAdminToken =
@accessToken = paste-access-token-here

GET {{TransitOps.Api_HostAddress}}/api/v1/health/live
Accept: application/json

###

GET {{TransitOps.Api_HostAddress}}/api/v1/health/ready
Accept: application/json

###

POST {{TransitOps.Api_HostAddress}}/api/v1/auth/bootstrap-admin
Accept: application/json
Content-Type: application/json
X-Bootstrap-Token: {{bootstrapAdminToken}}

{
  "username": "admin",
  "email": "admin@transitops.local",
  "password": "Admin!12345"
}

###

POST {{TransitOps.Api_HostAddress}}/api/v1/auth/login
Accept: application/json
Content-Type: application/json

{
  "username": "{{seededAdminUsername}}",
  "password": "{{seededAdminPassword}}"
}

###

GET {{TransitOps.Api_HostAddress}}/api/v1/transports
Accept: application/json
Authorization: Bearer {{accessToken}}

###

GET {{TransitOps.Api_HostAddress}}/api/v1/transports/{{transportId}}
Accept: application/json
Authorization: Bearer {{accessToken}}

###

POST {{TransitOps.Api_HostAddress}}/api/v1/transports
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "reference": "TR-200",
  "description": "High-priority route",
  "origin": "Madrid",
  "destination": "Barcelona",
  "plannedPickupAt": "2026-04-01T08:00:00Z",
  "plannedDeliveryAt": "2026-04-01T14:00:00Z"
}

###

PUT {{TransitOps.Api_HostAddress}}/api/v1/transports/{{transportId}}
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "reference": "TR-200-UPDATED",
  "description": "Updated route",
  "origin": "Seville",
  "destination": "Valencia",
  "plannedPickupAt": "2026-04-02T09:00:00Z",
  "plannedDeliveryAt": "2026-04-02T18:00:00Z"
}

###

PUT {{TransitOps.Api_HostAddress}}/api/v1/transports/{{transportId}}/assignment
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "vehicleId": "{{vehicleId}}",
  "driverId": "{{driverId}}"
}

###

PUT {{TransitOps.Api_HostAddress}}/api/v1/transports/{{transportId}}/status
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "targetStatus": "in_transit",
  "occurredAt": "2026-04-08T08:30:00Z"
}

###

GET {{TransitOps.Api_HostAddress}}/api/v1/vehicles
Accept: application/json
Authorization: Bearer {{accessToken}}

###

GET {{TransitOps.Api_HostAddress}}/api/v1/vehicles/{{vehicleId}}
Accept: application/json
Authorization: Bearer {{accessToken}}

###

GET {{TransitOps.Api_HostAddress}}/api/v1/drivers
Accept: application/json
Authorization: Bearer {{accessToken}}

###

GET {{TransitOps.Api_HostAddress}}/api/v1/drivers/{{driverId}}
Accept: application/json
Authorization: Bearer {{accessToken}}

###

GET {{TransitOps.Api_HostAddress}}/api/v1/transports/{{transportId}}/shipment-events
Accept: application/json
Authorization: Bearer {{accessToken}}

###

POST {{TransitOps.Api_HostAddress}}/api/v1/transports/{{transportId}}/shipment-events
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "eventType": "checkpoint",
  "eventDate": "2026-04-09T12:30:00Z",
  "location": "A-4 Km 35",
  "notes": "Manual shipment event creation example."
}

###
