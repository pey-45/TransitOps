{
  "info": {
    "name": "TransitOps API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the current TransitOps API surface."
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Live",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/live",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "health",
                "live"
              ]
            },
            "description": "Liveness probe."
          }
        },
        {
          "name": "Ready",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/ready",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "health",
                "ready"
              ]
            },
            "description": "Readiness probe with PostgreSQL connectivity check."
          }
        }
      ],
      "auth": {
        "type": "noauth"
      }
    },
    {
      "name": "Auth",
      "auth": {
        "type": "noauth"
      },
      "item": [
        {
          "name": "Bootstrap First Admin",
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Bootstrap-Token",
                "value": "{{bootstrapAdminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"email\": \"admin@transitops.local\",\n  \"password\": \"Admin!12345\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/bootstrap-admin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "bootstrap-admin"
              ]
            },
            "description": "One-time controlled setup endpoint. It only succeeds when no active admin exists and requires X-Bootstrap-Token from external configuration."
          }
        },
        {
          "name": "Login With Seeded Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const payload = pm.response.json();",
                  "  pm.collectionVariables.set(\"accessToken\", payload.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{seededAdminUsername}}\",\n  \"password\": \"{{seededAdminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Logs in with the seeded admin credentials and stores accessToken as a collection variable for protected requests."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            },
            "description": "Returns the current non-deleted users available to admins. The deterministic seed includes seed.admin and seed.operator by default."
          }
        },
        {
          "name": "Get User By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{managedUserId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{managedUserId}}"
              ]
            },
            "description": "Returns one managed user by id. The default {{managedUserId}} points to the seeded operator user."
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"managed.operator\",\n  \"email\": \"managed.operator@transitops.local\",\n  \"password\": \"Managed!12345\",\n  \"userRole\": \"operator\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            },
            "description": "Creates a managed user with a hashed password. Only admins can call this endpoint."
          }
        },
        {
          "name": "Change User Role",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userRole\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{managedUserId}}/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{managedUserId}}",
                "role"
              ]
            },
            "description": "Changes the user role. Demoting the last active admin is rejected with 409."
          }
        },
        {
          "name": "Set User Activation",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{managedUserId}}/activation",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{managedUserId}}",
                "activation"
              ]
            },
            "description": "Activates or deactivates a user. Deactivating the last active admin is rejected with 409."
          }
        }
      ]
    },
    {
      "name": "Transports",
      "item": [
        {
          "name": "Get All Transports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports"
              ]
            },
            "description": "Returns the current transport list from PostgreSQL. If you first run scripts/database/postgres/seed/002_seed_sample_data.sql, the active rows should include SEED-TR-001, SEED-TR-002, and SEED-TR-003, while soft-deleted SEED-TR-004 should be filtered out."
          }
        },
        {
          "name": "Get Transport By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}"
              ]
            },
            "description": "Returns one seeded transport by id when scripts/database/postgres/seed/002_seed_sample_data.sql has been applied. The default {{transportId}} points to SEED-TR-001."
          }
        },
        {
          "name": "Create Transport",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"TR-200\",\n  \"description\": \"High-priority route\",\n  \"origin\": \"Madrid\",\n  \"destination\": \"Barcelona\",\n  \"plannedPickupAt\": \"2026-04-01T08:00:00Z\",\n  \"plannedDeliveryAt\": \"2026-04-01T14:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports"
              ]
            },
            "description": "Creates a new planned transport when the reference is unique among active rows."
          }
        },
        {
          "name": "Update Transport",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"TR-200-UPDATED\",\n  \"description\": \"Updated route\",\n  \"origin\": \"Seville\",\n  \"destination\": \"Valencia\",\n  \"plannedPickupAt\": \"2026-04-02T09:00:00Z\",\n  \"plannedDeliveryAt\": \"2026-04-02T18:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}"
              ]
            },
            "description": "Updates the generic transport fields without changing assignment or lifecycle state."
          }
        },
        {
          "name": "Assign Transport",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleId\": \"{{vehicleId}}\",\n  \"driverId\": \"{{driverId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}/assignment",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}",
                "assignment"
              ]
            },
            "description": "Assigns a vehicle and a driver together to a planned transport. Both resources must exist, be active, and not be soft-deleted."
          }
        },
        {
          "name": "Transition Transport Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetStatus\": \"in_transit\",\n  \"occurredAt\": \"2026-04-08T08:30:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}",
                "status"
              ]
            },
            "description": "Transitions a transport through the explicit lifecycle rules. Starting the trip requires an assignment; delivered and cancelled remain terminal."
          }
        },
        {
          "name": "Delete Transport",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}"
              ]
            },
            "description": "Soft-deletes the target transport so it disappears from active reads while preserving historical rows."
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "Get All Vehicles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vehicles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "vehicles"
              ]
            },
            "description": "Returns the current active vehicle list from PostgreSQL. The default seeded dataset includes SEED-PLATE-001 and SEED-PLATE-002."
          }
        },
        {
          "name": "Get Vehicle By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vehicles/{{vehicleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "vehicles",
                "{{vehicleId}}"
              ]
            },
            "description": "Returns one seeded vehicle by id. The default {{vehicleId}} points to SEED-PLATE-001 / SEED-VEH-001."
          }
        }
      ]
    },
    {
      "name": "Drivers",
      "item": [
        {
          "name": "Get All Drivers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/drivers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "drivers"
              ]
            },
            "description": "Returns the current active driver list from PostgreSQL. The default seeded dataset includes SEED-DRV-001 and SEED-DRV-002."
          }
        },
        {
          "name": "Get Driver By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/drivers/{{driverId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "drivers",
                "{{driverId}}"
              ]
            },
            "description": "Returns one seeded driver by id. The default {{driverId}} points to SEED-DRV-001."
          }
        }
      ]
    },
    {
      "name": "Shipment Events",
      "item": [
        {
          "name": "Get Shipment Events By Transport",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}/shipment-events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}",
                "shipment-events"
              ]
            },
            "description": "Returns the seeded event history for the selected transport ordered by event date. The default {{transportId}} points to SEED-TR-001, which has seeded created and assigned events."
          }
        },
        {
          "name": "Create Shipment Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventType\": \"checkpoint\",\n  \"eventDate\": \"2026-04-09T12:30:00Z\",\n  \"location\": \"A-4 Km 35\",\n  \"notes\": \"Manual shipment event creation example.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}/shipment-events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}",
                "shipment-events"
              ]
            },
            "description": "Creates a shipment event for the selected transport using the authenticated caller as the persisted actor."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "transportId",
      "value": "40000000-0000-0000-0000-000000000001",
      "description": "Seeded transport SEED-TR-001 from scripts/database/postgres/seed/002_seed_sample_data.sql"
    },
    {
      "key": "vehicleId",
      "value": "30000000-0000-0000-0000-000000000001",
      "description": "Seeded vehicle SEED-PLATE-001 / SEED-VEH-001 from scripts/database/postgres/seed/002_seed_sample_data.sql"
    },
    {
      "key": "driverId",
      "value": "20000000-0000-0000-0000-000000000001",
      "description": "Seeded driver SEED-DRV-001 from scripts/database/postgres/seed/002_seed_sample_data.sql"
    },
    {
      "key": "seededAdminUsername",
      "value": "seed.admin",
      "description": "Seeded admin username from scripts/database/postgres/seed/002_seed_sample_data.sql"
    },
    {
      "key": "seededAdminPassword",
      "value": "SeedAdmin!123",
      "description": "Seeded admin password for manual local testing only"
    },
    {
      "key": "bootstrapAdminToken",
      "value": "",
      "description": "External bootstrap token required only for the first-admin bootstrap endpoint"
    },
    {
      "key": "accessToken",
      "value": "",
      "description": "Bearer token captured from the login request"
    },
    {
      "key": "seededAdminUserId",
      "value": "10000000-0000-0000-0000-000000000001"
    },
    {
      "key": "managedUserId",
      "value": "10000000-0000-0000-0000-000000000002"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  }
}
