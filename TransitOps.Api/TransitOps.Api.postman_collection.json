{
  "info": {
    "name": "TransitOps API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the current TransitOps API surface."
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Live",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/live",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "health",
                "live"
              ]
            },
            "description": "Liveness probe."
          }
        },
        {
          "name": "Ready",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/ready",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "health",
                "ready"
              ]
            },
            "description": "Readiness probe with PostgreSQL connectivity check."
          }
        }
      ]
    },
    {
      "name": "Transports",
      "item": [
        {
          "name": "Get All Transports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports"
              ]
            },
            "description": "Returns the current transport list from PostgreSQL."
          }
        },
        {
          "name": "Get Transport By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}"
              ]
            },
            "description": "Returns one transport by id or 404 if it does not exist."
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "Get All Vehicles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vehicles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "vehicles"
              ]
            },
            "description": "Current placeholder endpoint."
          }
        },
        {
          "name": "Get Vehicle By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vehicles/{{vehicleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "vehicles",
                "{{vehicleId}}"
              ]
            },
            "description": "Current placeholder endpoint that returns 404."
          }
        }
      ]
    },
    {
      "name": "Drivers",
      "item": [
        {
          "name": "Get All Drivers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/drivers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "drivers"
              ]
            },
            "description": "Current placeholder endpoint."
          }
        },
        {
          "name": "Get Driver By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/drivers/{{driverId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "drivers",
                "{{driverId}}"
              ]
            },
            "description": "Current placeholder endpoint that returns 404."
          }
        }
      ]
    },
    {
      "name": "Shipment Events",
      "item": [
        {
          "name": "Get Shipment Events By Transport",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}/shipment-events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}",
                "shipment-events"
              ]
            },
            "description": "Current placeholder endpoint."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5098"
    },
    {
      "key": "transportId",
      "value": "11111111-1111-1111-1111-111111111111"
    },
    {
      "key": "vehicleId",
      "value": "22222222-2222-2222-2222-222222222222"
    },
    {
      "key": "driverId",
      "value": "33333333-3333-3333-3333-333333333333"
    }
  ]
}
