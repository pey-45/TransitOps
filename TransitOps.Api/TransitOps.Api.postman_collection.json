{
  "info": {
    "name": "TransitOps API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for the current TransitOps API surface."
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Live",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/live",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "health",
                "live"
              ]
            },
            "description": "Liveness probe."
          }
        },
        {
          "name": "Ready",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/health/ready",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "health",
                "ready"
              ]
            },
            "description": "Readiness probe with PostgreSQL connectivity check."
          }
        }
      ]
    },
    {
      "name": "Transports",
      "item": [
        {
          "name": "Get All Transports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports"
              ]
            },
            "description": "Returns the current transport list from PostgreSQL. If you first run scripts/postgres/manual/002_seed_sample_data.sql, the active rows should include SEED-TR-001, SEED-TR-002, and SEED-TR-003, while soft-deleted SEED-TR-004 should be filtered out."
          }
        },
        {
          "name": "Get Transport By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}"
              ]
            },
            "description": "Returns one seeded transport by id when scripts/postgres/manual/002_seed_sample_data.sql has been applied. The default {{transportId}} points to SEED-TR-001."
          }
        },
        {
          "name": "Create Transport",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"TR-200\",\n  \"description\": \"High-priority route\",\n  \"origin\": \"Madrid\",\n  \"destination\": \"Barcelona\",\n  \"plannedPickupAt\": \"2026-04-01T08:00:00Z\",\n  \"plannedDeliveryAt\": \"2026-04-01T14:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports"
              ]
            },
            "description": "Creates a new planned transport when the reference is unique among active rows."
          }
        },
        {
          "name": "Update Transport",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"TR-200-UPDATED\",\n  \"description\": \"Updated route\",\n  \"origin\": \"Seville\",\n  \"destination\": \"Valencia\",\n  \"plannedPickupAt\": \"2026-04-02T09:00:00Z\",\n  \"plannedDeliveryAt\": \"2026-04-02T18:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}"
              ]
            },
            "description": "Updates the generic transport fields without changing assignment or lifecycle state."
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "Get All Vehicles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vehicles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "vehicles"
              ]
            },
            "description": "Current placeholder endpoint. The seed script scripts/postgres/manual/002_seed_sample_data.sql inserts vehicles SEED-PLATE-001 and SEED-PLATE-002 so the request variables already reference real seeded IDs for future implementation."
          }
        },
        {
          "name": "Get Vehicle By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/vehicles/{{vehicleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "vehicles",
                "{{vehicleId}}"
              ]
            },
            "description": "Current placeholder endpoint that returns 404 today. The default {{vehicleId}} matches seeded vehicle SEED-PLATE-001 from scripts/postgres/manual/002_seed_sample_data.sql."
          }
        }
      ]
    },
    {
      "name": "Drivers",
      "item": [
        {
          "name": "Get All Drivers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/drivers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "drivers"
              ]
            },
            "description": "Current placeholder endpoint. The seed script scripts/postgres/manual/002_seed_sample_data.sql inserts drivers SEED-DRV-001 and SEED-DRV-002 so the request variables already reference real seeded IDs for future implementation."
          }
        },
        {
          "name": "Get Driver By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/drivers/{{driverId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "drivers",
                "{{driverId}}"
              ]
            },
            "description": "Current placeholder endpoint that returns 404 today. The default {{driverId}} matches seeded driver SEED-DRV-001 from scripts/postgres/manual/002_seed_sample_data.sql."
          }
        }
      ]
    },
    {
      "name": "Shipment Events",
      "item": [
        {
          "name": "Get Shipment Events By Transport",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transports/{{transportId}}/shipment-events",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transports",
                "{{transportId}}",
                "shipment-events"
              ]
            },
            "description": "Current placeholder endpoint. The default {{transportId}} matches seeded transport SEED-TR-001, which has seeded shipment events in scripts/postgres/manual/002_seed_sample_data.sql."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "transportId",
      "value": "40000000-0000-0000-0000-000000000001",
      "description": "Seeded transport SEED-TR-001 from scripts/postgres/manual/002_seed_sample_data.sql"
    },
    {
      "key": "vehicleId",
      "value": "30000000-0000-0000-0000-000000000001",
      "description": "Seeded vehicle SEED-PLATE-001 / SEED-VEH-001 from scripts/postgres/manual/002_seed_sample_data.sql"
    },
    {
      "key": "driverId",
      "value": "20000000-0000-0000-0000-000000000001",
      "description": "Seeded driver SEED-DRV-001 from scripts/postgres/manual/002_seed_sample_data.sql"
    }
  ]
}
